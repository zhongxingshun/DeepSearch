# ==================================================
# DeepSearch 生产环境配置
# ==================================================
# 使用方法: cp .env.example .env && vi .env
# 密钥生成: openssl rand -hex 32
# deploy.sh 会自动生成 .env（如果不存在）

# ---------- 数据库 ----------
DB_NAME=deepsearch
DB_USER=deepsearch
DB_PASSWORD=CHANGE_ME

# ---------- Meilisearch ----------
MEILI_MASTER_KEY=CHANGE_ME

# ---------- 安全密钥（必须修改！）----------
JWT_SECRET_KEY=CHANGE_ME
APP_SECRET_KEY=CHANGE_ME

# ---------- 嵌入配置 ----------
# 默认只允许本站被同源页面 iframe 嵌入。
# 如需允许导航系统嵌入，填导航系统完整 origin，多个 origin 用空格分隔。
# 当前导航系统示例：FRAME_ANCESTORS="'self' http://192.168.254.99:8080"
FRAME_ANCESTORS="'self' http://192.168.254.99:8080"
